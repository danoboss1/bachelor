generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id         Int          @id @default(autoincrement())
  username   String       @unique @db.VarChar(50)
  password   String
  stats_knox stats_knox[]
  stats_tol  stats_tol[]
  stats_wcst stats_wcst[]
}

model stats_wcst {
  id                           Int      @id @default(autoincrement())
  time                         DateTime? @db.Timestamp(6)
  categories_completed         Int?     @db.SmallInt
  trials_administered          Int?     @db.SmallInt
  total_correct                Int?     @db.SmallInt
  total_error                  Int?     @db.SmallInt
  perseverative_responses      Int?     @db.SmallInt
  perseverative_errors         Int?     @db.SmallInt
  non_perseverative_errors     Int?     @db.SmallInt
  failure_to_maintain_set      Int?     @db.SmallInt
  trials_to_first_category     Int?     @db.SmallInt
  perseverativepercent         Decimal? @db.Decimal(5, 2)
  perseverativeerrorpercent    Decimal? @db.Decimal(5, 2)
  nonperseverativeerrorpercent Decimal? @db.Decimal(5, 2)
  errorpercent                 Decimal? @db.Decimal(5, 2)
  user_id                      Int?
  users                        users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_stats_wcst_user_id")
}

model stats_knox {
  id                        Int      @id @default(autoincrement())
  time                      DateTime? @db.Timestamp(6)
  threestepsequencescorrect Int?     @db.SmallInt
  fourstepsequencescorrect  Int?     @db.SmallInt
  fivestepsequencescorrect  Int?     @db.SmallInt
  sixstepsequencescorrect   Int?     @db.SmallInt
  sevenstepsequencescorrect Int?     @db.SmallInt
  eightstepsequencescorrect Int?     @db.SmallInt
  totalcorrect              Int?     @db.SmallInt
  user_id                   Int?
  totalscore                Float?
  users                     users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_stats_knox_user_id")
}

model stats_tol {
  id                        Int      @id @default(autoincrement())
  time                      DateTime? @db.Timestamp(6)
  fourmovessequencescorrect Int?     @db.SmallInt
  fivemovessequencescorrect Int?     @db.SmallInt
  sixmovessequencescorrect  Int?     @db.SmallInt
  totalcorrect              Int?     @db.SmallInt
  user_id                   Int?     @db.SmallInt
  totalscore                Float?
  users                     users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_stats_tol_user_id")
}
